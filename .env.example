# ─── Scout configuration ──────────────────────────────────────────────
# Bring your own model. Scout never ships credentials; you supply them here.
# Copy this file to `.env` and fill in the provider you want to use.

# The model to drive every agent. Pick ONE of the examples below.
# Tip: run `scout models` to print the exact IDs your credentials can use.
#
# ── FREE, real models (no credit card) - great for trying Scout ─────────
#   Groq (recommended free): groq/llama-3.3-70b-versatile   (fast, real tool calls)
#   Groq (alternatives):     groq/qwen/qwen3-32b · groq/openai/gpt-oss-120b
#   Google Gemini (free):    gemini/gemini-2.5-flash
#     Groq key:   https://console.groq.com/keys     (30s, email only)
#     Gemini key: https://aistudio.google.com/apikey (Google account only)
#
# ── Paid / premium ─────────────────────────────────────────────────────
#   Anthropic Claude (default): anthropic/claude-sonnet-4-6
#   Anthropic Claude (premium): anthropic/claude-opus-4-8
#   OpenAI GPT:                 openai/gpt-5.5
#
# ── Local / self-hosted ────────────────────────────────────────────────
#   Local Ollama (Qwen):        ollama/qwen2.5:14b
#   Local OpenAI-compat:        openai/qwen   (vLLM, LM Studio, TGI, etc.)
#
# ── No key at all (scripted demo, illustrative output only) ─────────────
#   Demo:                       mock
#
# Sonnet is the recommended default for serious use: Scout makes many tool calls
# per mission, so the speed/cost balance matters. Use Opus for maximum depth.
# Just trying it out? Start with groq/llama-3.3-70b-versatile - it's free.
SCOUT_MODEL=anthropic/claude-sonnet-4-6

# Provide the key for whichever provider you chose above. Leave the rest blank.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Only needed for self-hosted / local models (Ollama, vLLM, LM Studio, a box
# on your home network, etc). From inside Docker, reach your host machine with
# host.docker.internal. Examples:
#   Ollama:        http://host.docker.internal:11434
#   OpenAI-compat: http://host.docker.internal:8000/v1
SCOUT_API_BASE=

# Optional tuning.
SCOUT_MAX_TASKS=6          # max parallel-ish collection tasks the planner may create
SCOUT_MAX_STEPS=12         # max tool-calling steps per collector agent
SCOUT_TEMPERATURE=0.4

# ─── OSINT tool library ───────────────────────────────────────────────
# Scout auto-detects which specialized tools are usable and hands those to the
# agents. Run `scout tools` to see status for every tool. Keyless tools
# (airplanes.live, web-check, Reddit, data-broker opt-out) work out of the box.
#
# Allow only specific tools (comma-separated ids); leave blank to allow all:
SCOUT_TOOLS=
# Disable specific tools (comma-separated ids):
SCOUT_DISABLE_TOOLS=
#
# Keys/paths that light up additional tools (all optional):
GRAYHAT_API_KEY=          # exposed-bucket search (grayhatwarfare.com)
FACECHECK_API_TOKEN=      # reverse face search (facecheck.id) - paid
FACECHECK_TESTING=true    # true = no-cost demo mode (no real face results)
GEOSPY_API_KEY=           # AI image geolocation (geospy.ai) - commercial
MARINETRAFFIC_API_KEY=    # vessel tracking (marinetraffic.com / kpler.com)
SCOUT_WEBCHECK_URL=       # self-hosted web-check base URL (default: web-check.xyz)
SCOUT_TOOKIE_PATH=        # path to a cloned Alfredredbird/tookie-osint repo
SCOUT_GEOWIFI_PATH=       # path to GONZOsint/geowifi's geowifi.py
# Python-package tools install via extras, e.g.  pip install "scout[osint]"
#   scraping -> Scrapling   geo -> GeoCLIP   recon -> BBOT
#   accounts -> GHunt       scrub -> Presidio
